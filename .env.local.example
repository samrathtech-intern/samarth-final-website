# Upstash Redis credentials — for the visitor view counter
# -------------------------------------------------------
# 1. Go to https://console.upstash.com and create a free Redis database
# 2. Open your database → REST API tab
# 3. Copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
# 4. Copy this file, rename it to .env.local, and paste your real values below
# 5. NEVER commit .env.local to git (it is already in .gitignore)
# 6. Add the same variables in Vercel → Settings → Environment Variables

UPSTASH_REDIS_REST_URL=https://YOUR-DATABASE-NAME.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# Optional: starting seed count (default is 18132 if not set)
VIEW_COUNTER_SEED=18132

# Optional: Redis key name (default shown below)
VIEW_COUNTER_KEY=samarth-technoologies:visitor-count
