# Upstash Redis credentials for visitor counter
# ------------------------------------------------
# 1. Go to https://console.upstash.com and create a free Redis database
# 2. Copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN from the REST API section
# 3. Copy this file, rename it to .env.local, and paste your real values below
# 4. NEVER commit .env.local to git (it is already in .gitignore)

KV_REST_API_URL=https://YOUR-DATABASE-URL.upstash.io
KV_REST_API_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# Optional: starting seed count (default is 18132 if not set)
VIEW_COUNTER_SEED=18132

# Optional: Redis key name (default shown below)
VIEW_COUNTER_KEY=samarth-technoologies:visitor-count
